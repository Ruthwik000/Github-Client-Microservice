# Server Configuration
PORT=3000
NODE_ENV=development

# GitHub (Optional - for private repositories)
GITHUB_TOKEN=

# Groq API (Required)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Pinecone (Required)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here
PINECONE_INDEX_NAME=github-code-search

# Redis (Not used - application uses in-memory cache)
# REDIS_HOST=
# REDIS_PORT=
# REDIS_PASSWORD=
# REDIS_DB=

# Storage
CACHE_DIR=./cache
MAX_FILE_SIZE_MB=10
MAX_REPO_SIZE_MB=1000

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_FILE=100

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
